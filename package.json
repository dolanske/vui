{
  "name": "@dolanske/vui",
  "type": "module",
  "version": "1.11.4",
  "private": false,
  "description": "Brother in Christ there's a new UI library",
  "author": "dolanske",
  "license": "GPL-3.0",
  "sass": "src/index.scss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dolanske/vui.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "component",
    "component library",
    "vue3 components"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/vui.js"
    },
    "./style": {
      "import": "./dist/vui.css",
      "require": "./dist/vui.css",
      "default": "./dist/vui.css"
    }
  },
  "main": "./dist/vui.js",
  "module": "./dist/vui.js",
  "browser": "./dist/vui.js",
  "unpkg": "./dist/vui.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "./dist/*",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host",
    "build": "vue-tsc -b && vite build",
    "build:pages": "vue-tsc -b && vite build --mode pages",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@iconify-prerendered/vue-ph": "^0.28.1714973607",
    "@types/node": "^25.6.0",
    "@vuepic/vue-datepicker": "^12.1.0",
    "@vueuse/core": "^14.2.1",
    "sass": "^1.99.0",
    "vaul-vue": "^0.4.1",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.9",
    "baseline-browser-mapping": "^2.10.23",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "jsdom": "^29.1.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
