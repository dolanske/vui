{
  "name": "@dolanske/vui",
  "type": "module",
  "version": "1.17.0",
  "private": false,
  "description": "Brother in Christ there's a new UI library",
  "author": "dolanske",
  "license": "GPL-3.0",
  "sass": "src/index.scss",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dolanske/vui.git"
  },
  "keywords": [
    "vue",
    "vue3",
    "component",
    "component library",
    "vue3 components",
    "design system",
    "ui library"
  ],
  "sideEffects": [
    ".css",
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/vui.js"
    },
    "./style": {
      "import": "./dist/vui.css",
      "require": "./dist/vui.css",
      "default": "./dist/vui.css"
    }
  },
  "main": "./dist/vui.js",
  "module": "./dist/vui.js",
  "browser": "./dist/vui.js",
  "unpkg": "./dist/vui.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "./dist/",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "docs": "npm run dev --prefix docs",
    "dev:lan": "vite --host",
    "build": "vue-tsc -b && vite build",
    "build:pages": "vue-tsc -b && vite build --mode pages",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@floating-ui/vue": "^2.0.0",
    "@iconify-prerendered/vue-ph": "^0.28.1714973607",
    "@vuepic/vue-datepicker": "^14.0.0",
    "@vueuse/core": "^14.3.0",
    "emojibase": "^17.0.0",
    "vaul-vue": "^0.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@types/node": "^26.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "baseline-browser-mapping": "^2.10.38",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "jsdom": "^29.1.1",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue": "^3.5.38",
    "vue-tsc": "^3.3.5"
  }
}
